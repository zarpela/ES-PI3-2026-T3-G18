rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    match /profile_pictures/{fileName} {

      allow read: if true;

      allow write: if request.auth != null
        && fileName == request.auth.uid + ".jpg"
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType == 'image/jpeg';
    }
  }
}